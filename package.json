{
  "name": "benchmark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.18.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bench": "tsx src/benchmark.ts",
    "bench:msgpack": "tsx src/benchmark.ts --twilic-vs-msgpack-only",
    "bench:max": "tsx src/benchmark.ts --mode max --backend napi --time-ms 3000 --warmup-ms 1000",
    "bench:wasm": "tsx src/benchmark.ts --backend wasm",
    "format": "prettier --write \"{README.md,package.json,tsconfig.json,src/**/*.ts}\"",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "bson": "^7.2.0",
    "cbor-x": "^1.6.4",
    "cli-table3": "^0.6.5",
    "@twilic/core": "file:../twilic-js",
    "tinybench": "^2.9.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/node": "^24.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.2"
  }
}
